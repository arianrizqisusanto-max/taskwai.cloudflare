rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if caller is an authenticated staff of the given restaurant
    function isStaffOf(restaurantId) {
      return request.auth != null && 
        exists(/databases/$(database)/documents/staff_sessions/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/staff_sessions/$(request.auth.uid)).data.restaurantId == restaurantId;
    }

    // Helper: check if request is from the master admin email
    function isMasterAdmin() {
      return request.auth != null && request.auth.token.email == 'arianrisqi@gmail.com';
    }
    
    // Restaurants
    match /restaurants/{restaurantId} {
      allow read, update: if request.auth != null && (
        restaurantId == 'rest_' + request.auth.uid || isStaffOf(restaurantId) || isMasterAdmin()
      );
      allow create, delete: if request.auth != null && (restaurantId == 'rest_' + request.auth.uid || isMasterAdmin());
    }
    
    // Expenses
    match /expenses/{expensesId} {
      allow read: if request.auth != null && (
        expensesId == 'exp_' + request.auth.uid || 
        (exists(/databases/$(database)/documents/staff_sessions/$(request.auth.uid)) && 
         'exp_' + get(/databases/$(database)/documents/staff_sessions/$(request.auth.uid)).data.ownerId == expensesId)
      );
      allow write: if request.auth != null && expensesId == 'exp_' + request.auth.uid;
    }
    
    // Daily profit logs — separated read/create/update/delete for clean query validation
    match /daily_profit/{profitId} {
      // READ: owner can read their own restaurant's data, staff can read their assigned restaurant, admin can read all
      allow read: if request.auth != null && (
        resource.data.restaurantId == 'rest_' + request.auth.uid ||
        isStaffOf(resource.data.restaurantId) ||
        isMasterAdmin()
      );
      
      // CREATE: owner or staff can create new entries for their restaurant
      allow create: if request.auth != null && (
        request.resource.data.restaurantId == 'rest_' + request.auth.uid ||
        isStaffOf(request.resource.data.restaurantId)
      );
      
      // UPDATE/DELETE: owner or staff can modify entries belonging to their restaurant
      allow update, delete: if request.auth != null && (
        resource.data.restaurantId == 'rest_' + request.auth.uid ||
        isStaffOf(resource.data.restaurantId)
      );
    }

    // Staff accounts: public read for login; write by owner only
    match /staff_accounts/{hash} {
      allow read: if true;
      allow write: if request.auth != null && 
        (resource == null || resource.data.ownerId == request.auth.uid) &&
        (request.resource == null || request.resource.data.ownerId == request.auth.uid);
    }

    // Staff sessions: users can only manage their own session
    match /staff_sessions/{sessionUid} {
      allow read, write: if request.auth != null && (request.auth.uid == sessionUid || isMasterAdmin());
    }
  }
}
